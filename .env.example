# ── WealthWise Environment Variables ─────────────────────────────
# Copy this file to .env and fill in your actual keys

# ── Required ──────────────────────────────────────────────────────

# OpenRouter API Key (Free at https://openrouter.ai)
OPENROUTER_API_KEY=sk-or-your-key-here

# Clerk Publishable Key (Free at https://clerk.com)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your-clerk-key-here

# ── Optional ──────────────────────────────────────────────────────

# OpenAI API Key (for GPT-4o upgrade — https://platform.openai.com)
# OPENAI_API_KEY=sk-your-openai-key-here

# Backend URL (default: http://localhost:5000)
# VITE_API_URL=http://localhost:5000
